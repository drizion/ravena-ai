-        let caption = null;
-        let mediaInfo = null;
-
-        // remove o @nomedobot pra facilitar
-        if (message.text) {
-          type = 'text';
-          content = message.text.replace(`@${this.telegramBotName}`, "");
-        } else if (message.photo) {
-          type = 'image';
