+
+	/**
+	 * Truncate string to limit, keeping start and end
+	 * @param {string} str
+	 * @param {number} limit
+	 * @returns {string}
+	 */
+	_truncateString(str, limit) {
+		if (!str) return "";
+		if (typeof str !== "string") str = String(str);
+		if (str.length <= limit * 2) return str;
+
+		return str.substring(0, limit) + "[...]" + str.substring(str.length - limit);
