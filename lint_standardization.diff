+	async _writeCache(cache) {
+		try {
+			await fs.writeFile(this.cachePath, JSON.stringify(cache, null, 2), "utf8");
+		} catch (error) {
+			logger.error("Erro ao escrever cache:", error);
+			throw error;
+		}
+	}
+
+	/**
