-      const currentDay = now.getDay();
-      
-      // Verifica se o dia atual está na lista de dias permitidos
-      const isDayAllowed = allowedTimes.daysOfWeek.some(day => {
-        const mappedDay = dayMap[day.toLowerCase()];
