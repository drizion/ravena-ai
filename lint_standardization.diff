+			"Spanish (ES)",
+			"Russian (RU)",
+			"French (FR)",
+			"German (DE)",
+			"Italian (IT)",
+			"Japanese (JA)",
+			"Chinese (ZH)",
+			"Korean (KO)",
+			"Arabic (AR)",
