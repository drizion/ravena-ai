+				this.logger.error(`Unexpected Twitch token response: ${JSON.stringify(response.data)}`);
+				return null;
+			}
+		} catch (error) {
+			this.logger.error(`Error refreshing Twitch token: ${error.message}`);
+			return null;
+		}
