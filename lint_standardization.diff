+			const base64Png = finalImageBuffer.toString("base64");
+
+			return base64Png;
+		} catch (error) {
+			this.logger.error(
+				`[convertToSquarePNGImage] [${tempId}] Error during Sharp processing: ${error.message}`,
+				error.stack
+			);
