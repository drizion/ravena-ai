# -----------------------------------------------------
# Configurações do tipa
# -----------------------------------------------------
TIPA_TOKEN=             				# https://tipa.ai/settings/apps (WEBHOOKS)
DONATION_LINK=https://tipa.ai/moothz
DONATION_GOAL_AMOUNT=1000
DONATION_GOAL_DESCRIPTION=Pagar o moothz!

# ===============================================
# Configurações do Bot - Telegram
# ===============================================

# Um token secreto para validar os webhooks e garantir que eles venham do Telegram
TELEGRAM_SECRET_TOKEN="seu_token_secreto_super_seguro"

# IDs de chat para funcionalidades específicas (logs, avisos, etc.)
TELEGRAM_GRUPO_LOGS="-1001234567890"
TELEGRAM_GRUPO_AVISOS="-1001234567891"
